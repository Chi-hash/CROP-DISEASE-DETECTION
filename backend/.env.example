# Copy this file to .env and fill in your values

# ── Hugging Face (Real AI) ─────────────────────────────────────────────────
# Get a FREE token at https://huggingface.co/settings/tokens
# Without a token the app still works but may hit rate limits during busy periods.
HF_API_TOKEN=

# Optional: swap to a different PlantVillage-trained model
HF_MODEL_ID=linkanjarad/mobilenet-v2-plant-disease-identification

# ── Plant.id API (Alternative real AI) ────────────────────────────────────
# Get a free key at https://plant.id  (not used by default)
PLANT_ID_API_KEY=

# ── Server settings ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
